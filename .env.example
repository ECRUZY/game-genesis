# Скопируй этот файл в .env и заполни своими значениями
# НЕ загружай .env на GitHub!

# База данных (Railway даст тебе эту строку автоматически)
DATABASE_URL=postgresql://postgres:password@localhost:5432/gamegenesis

# JWT секрет — придумай любую длинную строку
JWT_SECRET=game_genesis_super_secret_key_2025_change_this

# Порт сервера
PORT=3000

# Название сайта (для писем)
APP_NAME=Game Genesis
